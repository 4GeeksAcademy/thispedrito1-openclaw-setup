 -H \\\"Authorization: Token 6853e727ba8243e8fd4afef911953857f167a292\\\" \\\\\\n  -H \\\"Accept: application/json\\\" 2>&1 | head -20\"}"}],"api":"openai-completions","provider":"litellm","model":"madrid-spain/openrouter/deepseek/deepseek-v4-flash","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1782502734162,"responseId":"gen-1782502735-o7a7liEeQH6rNlXsFADl"}}
